.bazelrc.user

# rust-analyzer (generated by bazel run @rules_rust//tools/rust_analyzer:gen_rust_project)
rust-project.json

# Bazel convenience symlinks — machine/worktree-specific, regenerated on every
# build (incl. per-worktree `bazel-agent-*`). Never commit. Matches the `bazel-`
# prefix only, NOT the tracked `bazel/` source dir.
/bazel-*

# Bazel module lockfile — regenerated locally; not tracked per repo convention.
/MODULE.bazel.lock

# Rust build output.
/target/
