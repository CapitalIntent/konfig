# Local overrides (BuildBuddy key, personal flags) — not committed.
try-import %workspace%/.bazelrc.user

# Disk cache — populated by GHA actions/cache; speeds up incremental CI builds.
build --disk_cache=~/.cache/bazel-disk-cache

# Required for tokio-console and dial9-tokio-telemetry.
build --@rules_rust//:extra_rustc_flags=--cfg=tokio_unstable
build --@rules_rust//:extra_rustc_flags=-Cforce-frame-pointers=yes

# CI profile — disable disk cache path expansion for remote runners.
build:ci --disk_cache=

# Portable x86-64 instruction floor for SHIPPED x86_64 binaries (CU-86aj4guza).
# Confirmed root cause of the recurring loadtest-gate exit-132 SIGILL: without a
# pinned target-cpu the konfig rust binary's effective baseline resolved ABOVE
# some runner/prod CPUs and executed an illegal instruction during pre-main init
# (empty logs, deterministic on non-AVX512 pools — proven by acceptance run
# 28059825635 going green once pinned). x86-64-v2 (cx16 + sse4.2 + popcnt) is the
# HONEST floor: snmalloc already requires CMPXCHG16B (cx16), so the binary cannot
# run below v2 anyway — pinning v1 would buy no portability and only cost perf.
#
# x86_64-ONLY: the cpu name is invalid for aarch64, so this MUST NOT be a global
# `build` flag — publish-images builds an arm64 matrix leg with --config=ci. Only
# the amd64 image/build steps opt in via `--config=x86-baseline`; arm64 never does.
build:x86-baseline --@rules_rust//:extra_rustc_flags=-Ctarget-cpu=x86-64-v2

# Release profile — optimised binaries with native CPU tuning.
build:release -c opt
build:release --@rules_rust//:extra_rustc_flags=-Cpanic=abort
build:release --@rules_rust//:extra_rustc_flags=-Cstrip=symbols
build:release --@rules_rust//:extra_rustc_flags=-Ctarget-cpu=native

# Linux arm64 target — used when building container images on Apple Silicon.
build:linux-arm64 --platforms=//platforms:linux_arm64

# Pipelined compilation — ~20% faster incremental builds for crates w/ many deps
build --@rules_rust//rust/settings:pipelined_compilation=True

# JSON error output for CI parsing
build --@rules_rust//rust/settings:error_format=json

# Version stamping (commit SHA + timestamp into binaries)
build --workspace_status_command=tools/workspace_status.sh
